<?xml version="1.0" encoding="utf-8"?>
<Defs>

    <PipeSystem.ProcessDef>
		<defName>KIM_VFEFactory_SynthesizeNeutroamineFromInsect</defName>
		<label>Synthesize neutroamine from insect meat</label>
		<labelOverride>Synthesize neutroamine from insect meat</labelOverride>
		<description>Synthesize neutroamine more efficiently from chemfuel and unique chemicals compounds found in insect bodies.</description>
		<priorityInBillList>1</priorityInBillList>
		<spawnOnInteractionCell>true</spawnOnInteractionCell>
		<autoGrabFromHoppers>true</autoGrabFromHoppers>
		<autoInputSlots>			
			<li>(-1,0,2)</li>
			<li>(1,0,2)</li>
		</autoInputSlots>
		<ticks>4800</ticks>
		<ingredients>
			<li>
				<thing>Chemfuel</thing>
				<countNeeded>5</countNeeded>
			</li>
			<li>
				<thing>Meat_Megaspider</thing>
				<countNeeded>30</countNeeded>			
			</li>
		</ingredients>
		<results>
			<li>
				<thing>Neutroamine</thing>
				<count>10</count>
			</li>
		</results>
		<isFactoryProcess>true</isFactoryProcess>
		<autoExtract>true</autoExtract>
		<onlyGrabAndOutputToFactoryHoppers>true</onlyGrabAndOutputToFactoryHoppers>
		<sustainerWhenWorking>true</sustainerWhenWorking>
		<sustainerDef>VFEFactory_AutomatedDrugsSustainer</sustainerDef>
		<effecterWhenWorking>true</effecterWhenWorking>
		<effecterDef>VFEFactory_Cook</effecterDef>
	</PipeSystem.ProcessDef>
	
</Defs>