<?xml version="1.0" encoding="utf-8"?>
<Patch>
	<!-- Cheaper factory floor -->
	
	<Operation Class="PatchOperationReplace">
        <xpath>Defs/TerrainDef[defName="VFEF_FactoryFloor"]/costList/Steel</xpath>
        <value>
            <Steel>2</Steel>
        </value>
    </Operation>
	
	<!-- No move speed penalty because why tf was this here in the first place -->
	
	<Operation Class="PatchOperationReplace">
	    <xpath>Defs/TerrainDef[defName="VFEF_FactoryFloor"]/pathCost</xpath>
        <value>
            <pathCost>0</pathCost>
        </value>
    </Operation>
	
</Patch>
