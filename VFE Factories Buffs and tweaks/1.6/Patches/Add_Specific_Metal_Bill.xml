<?xml version="1.0" encoding="utf-8"?>
<Patch>
	<!-- Add specific metal bills to the drill -->
	
	<Operation Class="PatchOperationAdd">
    <xpath>/Defs/ThingDef[defName="VFEFactory_AutomatedDrillPlatform"]/comps/li[@Class="PipeSystem.CompProperties_AdvancedResourceProcessor"]/processes</xpath>
        <value>
            <li>KIM_VFEFactory_DigForSteel</li>
			<li>KIM_VFEFactory_DigForSilver</li>
			<li>KIM_VFEFactory_DigForPlasteel</li>
			<li>KIM_VFEFactory_DigForJade</li>
			<li>KIM_VFEFactory_DigForGold</li>
			<li>KIM_VFEFactory_DigForUranium</li>
        </value>
    </Operation>
	
</Patch>
