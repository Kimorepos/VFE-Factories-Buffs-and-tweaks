<?xml version="1.0" encoding="utf-8" ?>
<Defs>
	<PipeSystem.ProcessDef>
		<defName>KIM_VFEFactory_MakeChemfuelFromFecalSludge</defName>
		<label>Make chemfuel from fecal sludge</label>
		<labelOverride>Make chemfuel from fecal sludge</labelOverride>
		<description>Make a batch of chemfuel by liquifying and treating fecal sludge into chemfuel.</description>
		<priorityInBillList>10</priorityInBillList>
		<spawnOnInteractionCell>true</spawnOnInteractionCell>
		<autoGrabFromHoppers>true</autoGrabFromHoppers>
		<autoInputSlots>
			<li>(0,0,3)</li>
			<li>(1,0,3)</li>
			<li>(-1,0,3)</li>
		</autoInputSlots>
		<ticks>5000</ticks>
		<ingredients>
			<li>
				<thing>FecalSludge</thing>
				<countNeeded>75</countNeeded>
			</li>
		</ingredients>
		<results>
			<li>
				<thing>Chemfuel</thing>
				<count>10</count>
			</li>
		</results>
		<isFactoryProcess>true</isFactoryProcess>
		<autoExtract>true</autoExtract>
		<onlyGrabAndOutputToFactoryHoppers>true</onlyGrabAndOutputToFactoryHoppers>
		<researchPrerequisites>
			<li>BiofuelRefining</li>
			<li>VFE_BasicFactories</li>
		</researchPrerequisites>
		<sustainerWhenWorking>true</sustainerWhenWorking>
		<sustainerDef>VFEFactory_AutomatedBrewingSustainer</sustainerDef>
		<effecterWhenWorking>true</effecterWhenWorking>
		<effecterDef>VFEFactory_Cook</effecterDef>
		<maxOutputCount>150</maxOutputCount>
	</PipeSystem.ProcessDef>
	
</Defs>