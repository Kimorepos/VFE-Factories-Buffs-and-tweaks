<?xml version="1.0" encoding="utf-8" ?>
<Defs>
	<PipeSystem.ProcessDef>
		<defName>KIM_VFEFactory_MakeGlassFromChunk</defName>
		<label>Smelt glass from stone chunk</label>
		<labelOverride>Smelt glass from stone chunk</labelOverride>
		<description>Use heat and strong electromagnets to melt stone chunks into glass.</description>
		<priorityInBillList>10</priorityInBillList>
		<spawnOnInteractionCell>true</spawnOnInteractionCell>
		<autoGrabFromHoppers>true</autoGrabFromHoppers>
		<autoInputSlots>
			<li>(0,0,3)</li>
			<li>(1,0,3)</li>
			<li>(-1,0,3)</li>
		</autoInputSlots>
		<ticks>7500</ticks>
		<ingredients>
			<li>
				<thingCategory>StoneChunks</thingCategory>
				<countNeeded>1</countNeeded>
				
			</li>
		</ingredients>
		<results>
			<li>
				<thing>RB_Glass</thing>
				<count>6</count>
			</li>
		</results>
		<isFactoryProcess>true</isFactoryProcess>
		<autoExtract>true</autoExtract>
		<onlyGrabAndOutputToFactoryHoppers>true</onlyGrabAndOutputToFactoryHoppers>
		<sustainerWhenWorking>true</sustainerWhenWorking>
		<sustainerDef>VFEFactory_AutomatedSmeltingSustainer</sustainerDef>
		<effecterWhenWorking>true</effecterWhenWorking>
		<effecterDef>VFEFactory_Smelt</effecterDef>
		<maxOutputCount>75</maxOutputCount>
	</PipeSystem.ProcessDef>
	
	<PipeSystem.ProcessDef>
		<defName>KIM_VFEFactory_MakeBalisticGlass</defName>
		<label>Fuse balistic glass from glass and plasteel</label>
		<labelOverride>Fuse balistic glass from glass and plasteel</labelOverride>
		<description>Use intense heat to combine thin layers of plasteel within glass, making sturdy balistic glass.</description>
		<priorityInBillList>10</priorityInBillList>
		<spawnOnInteractionCell>true</spawnOnInteractionCell>
		<autoGrabFromHoppers>true</autoGrabFromHoppers>
		<autoInputSlots>
			<li>(-2,0,3)</li>
			<li>(0,0,3)</li>
			<li>(2,0,3)</li>
			
		</autoInputSlots>
		<ticks>15000</ticks>
		<ingredients>
			<li>
				<thing>Plasteel</thing>
				<countNeeded>5</countNeeded>
			</li>
			<li>
				<thing>RB_Glass</thing>
				<countNeeded>6</countNeeded>
			</li>
			
		</ingredients>
		<results>
			<li>
				<thing>RB_BallisticGlass</thing>
				<count>3</count>
			</li>
		</results>
		<isFactoryProcess>true</isFactoryProcess>
		<autoExtract>true</autoExtract>
		<onlyGrabAndOutputToFactoryHoppers>true</onlyGrabAndOutputToFactoryHoppers>
		<researchPrerequisites>
			<li>VFE_ComplexFactories</li>
		</researchPrerequisites>
		<effecterWhenWorking>true</effecterWhenWorking>
		<effecterDef>VFEFactory_Smelt</effecterDef>
		<sustainerWhenWorking>true</sustainerWhenWorking>
		<sustainerDef>VFEFactory_AutomatedSmeltingSustainer</sustainerDef>
		<maxOutputCount>75</maxOutputCount>
	</PipeSystem.ProcessDef>
</Defs>